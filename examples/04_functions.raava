// 04_functions.raava — Function declarations and calls
fn add(a: int, b: int) -> int {
    return a + b;
}

fn factorial(n: int) -> int {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

let result: int = add(3, 4);
print result;

let fact: int = factorial(5);
print fact;
